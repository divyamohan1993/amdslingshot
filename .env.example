# =============================================================================
# JalNetra - Environment Configuration
# Copy this file to .env and update values for your deployment.
# =============================================================================

# ---------------------------------------------------------------------------
# Application Settings
# ---------------------------------------------------------------------------
# Environment: production, staging, development
JALNETRA_ENV=production

# Secret key for JWT token signing (CHANGE THIS - use: openssl rand -hex 32)
JALNETRA_SECRET_KEY=change-me-generate-a-random-secret-key

# Application port
JALNETRA_PORT=8000

# Number of uvicorn worker processes
JALNETRA_WORKERS=2

# Log level: debug, info, warning, error, critical
JALNETRA_LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# SQLite database path (inside Docker volume)
JALNETRA_DATABASE_URL=sqlite+aiosqlite:///app/data/jalnetra.db

# ---------------------------------------------------------------------------
# API Configuration
# ---------------------------------------------------------------------------
# API path prefix
JALNETRA_API_PREFIX=/api/v1

# CORS allowed origins (comma-separated, or * for all)
JALNETRA_CORS_ORIGINS=*

# Maximum number of sensor nodes supported
JALNETRA_MAX_SENSORS=100

# ---------------------------------------------------------------------------
# Model Configuration
# ---------------------------------------------------------------------------
# Directory containing trained model weights
JALNETRA_MODEL_DIR=/app/models

# Model inference device: cpu, cuda
JALNETRA_DEVICE=cpu

# Prediction confidence threshold (0.0-1.0)
JALNETRA_CONFIDENCE_THRESHOLD=0.7

# ---------------------------------------------------------------------------
# Data Directories
# ---------------------------------------------------------------------------
JALNETRA_DATA_DIR=/app/data
JALNETRA_LOG_DIR=/app/logs

# ---------------------------------------------------------------------------
# Alerts & Notifications (optional)
# ---------------------------------------------------------------------------
# Email address for critical water quality alerts
JALNETRA_ALERT_EMAIL=

# Webhook URL for alert notifications (e.g., Slack, Discord)
JALNETRA_ALERT_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# Authentication (optional)
# ---------------------------------------------------------------------------
# Default admin credentials (change after first login)
JALNETRA_ADMIN_USERNAME=admin
JALNETRA_ADMIN_PASSWORD=change-me-on-first-login

# JWT token expiration in minutes
JALNETRA_TOKEN_EXPIRE_MINUTES=1440

# ---------------------------------------------------------------------------
# GCP Configuration (for backup and monitoring)
# ---------------------------------------------------------------------------
# GCP project ID (for Cloud Storage backups)
# GCP_PROJECT_ID=your-gcp-project-id

# Cloud Storage bucket for backups
# GCP_BACKUP_BUCKET=your-project-jalnetra-backups

# ---------------------------------------------------------------------------
# Timezone
# ---------------------------------------------------------------------------
TZ=Asia/Kolkata
